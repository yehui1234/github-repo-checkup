# Server
PORT=3000

# AI provider:
# deepseek, dashscope, aliyun, openai, openrouter, groq, mistral,
# siliconflow, anthropic, gemini, ollama, or compatible
AI_PROVIDER=deepseek
AI_API_KEY=replace_with_your_api_key
AI_MODEL=deepseek-chat

# Optional: custom endpoint for local models, private deployments,
# regional endpoints, or other OpenAI-compatible services.
# AI_BASE_URL=http://127.0.0.1:11434/v1
# AI_PROTOCOL=openai

# Provider-specific API key aliases (optional)
# DEEPSEEK_API_KEY=replace_with_your_deepseek_key
# DASHSCOPE_API_KEY=replace_with_your_dashscope_key

# Optional: increases the GitHub REST API rate limit.
# GITHUB_TOKEN=github_pat_xxx

# Optional: HTTP proxy. On Windows, the application also attempts to
# detect the enabled system proxy automatically.
# PROXY_URL=http://127.0.0.1:10808
